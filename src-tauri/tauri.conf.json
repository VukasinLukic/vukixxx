{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Vukixxx",
  "version": "1.0.0",
  "identifier": "com.vukixxx.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Vukixxx - AI Context Workbench",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": false,
        "transparent": false,
        "center": true,
        "maximized": true
      },
      {
        "label": "widget",
        "title": "Vukixxx Widget",
        "url": "widget.html",
        "width": 340,
        "height": 420,
        "minWidth": 280,
        "minHeight": 350,
        "maxWidth": 600,
        "maxHeight": 800,
        "decorations": false,
        "transparent": false,
        "resizable": true,
        "alwaysOnTop": true,
        "visible": false,
        "skipTaskbar": true
      },
      {
        "label": "save-widget",
        "title": "Vukixxx - Save Prompt",
        "url": "save-widget.html",
        "width": 340,
        "height": 480,
        "minWidth": 280,
        "minHeight": 400,
        "maxWidth": 600,
        "maxHeight": 800,
        "decorations": false,
        "transparent": false,
        "resizable": true,
        "alwaysOnTop": true,
        "visible": false,
        "skipTaskbar": true
      }
    ],
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true,
      "tooltip": "Vukixxx"
    },
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self'; img-src 'self' data: blob:; connect-src 'self' https://generativelanguage.googleapis.com https://api.anthropic.com http://localhost:11434 http://127.0.0.1:11434"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    }
  },
  "plugins": {}
}